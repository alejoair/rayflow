# Files to keep OUT of the published package (sdist/wheel).
# CLAUDE.md is internal tooling guidance for the Claude Code agent, not user docs.
exclude CLAUDE.md
prune docs

# Generated LLM-orientation file map, workflow checklists, scenario
# narratives, and the CLAUDE.md claim breakdown — internal tooling
# artifacts, not user docs.
exclude rayflow_file_map.json
exclude rayflow_workflows.json
exclude rayflow_scenarios.json
exclude RAYFLOW_SOURCE_OF_TRUTH.json
exclude rayflow_issues.json
