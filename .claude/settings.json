{
  "env": {
    "ANTHROPIC_API_KEY": "1234",
    "ANTHROPIC_BASE_URL": "http://192.168.59.102:8123/",
    "ANTHROPIC_MODEL": "claude-sonnet-4",
    "ANTHROPIC_SMALL_FAST_MODEL": "claude-3-5-haiku"
  },
  "permissions": {
    "deny": [
      "Search",
      "Explore"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/file_map_context.py 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/dependents_reminder.py 2>/dev/null || true",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/staleness_guard.py 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/session_orientation.py 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/prompt_file_hints.py 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
