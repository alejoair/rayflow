{
  "name": "suma",
  "version": "1",
  "inputs": {
    "a": "int",
    "b": "int"
  },
  "outputs": {
    "result": "int"
  },
  "variables": [],
  "events": [],
  "nodes": [
    {
      "id": "entry",
      "type": "FlowInput"
    },
    {
      "id": "add",
      "type": "Add",
      "exec_in": "entry",
      "inputs": {
        "a": "entry.a",
        "b": "entry.b"
      }
    },
    {
      "id": "exit",
      "type": "FlowOutput",
      "exec_in": "add",
      "inputs": {
        "result": "add.result"
      }
    }
  ]
}
