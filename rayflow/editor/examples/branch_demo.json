{
  "name": "branch_demo",
  "version": "1",
  "outputs": {
    "result": "int"
  },
  "events": [],
  "nodes": [
    { "id": "entry", "type": "EntryXBool" },
    {
      "id": "branch",
      "type": "Branch",
      "exec_in": "entry",
      "inputs": { "condition": "entry.use_positive" }
    },
    {
      "id": "add_pos",
      "type": "Add",
      "exec_in": "branch.true",
      "inputs": { "a": "entry.x", "b": 100 }
    },
    {
      "id": "add_neg",
      "type": "Add",
      "exec_in": "branch.false",
      "inputs": { "a": "entry.x", "b": -100 }
    },
    {
      "id": "exit_true",
      "type": "FlowOutput",
      "exec_in": "add_pos",
      "inputs": { "result": "add_pos.result" }
    },
    {
      "id": "exit_false",
      "type": "FlowOutput",
      "exec_in": "add_neg",
      "inputs": { "result": "add_neg.result" }
    }
  ]
}
