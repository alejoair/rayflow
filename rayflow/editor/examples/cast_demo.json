{
  "name": "cast_demo",
  "version": "1",
  "outputs": {
    "texto": "str"
  },
  "variables": [],
  "events": [],
  "nodes": [
    {
      "id": "entry",
      "type": "EntryX"
    },
    {
      "id": "to_str",
      "type": "ToStr",
      "exec_in": "entry",
      "inputs": {
        "value": "entry.x"
      }
    },
    {
      "id": "exit",
      "type": "FlowOutput",
      "exec_in": "to_str",
      "inputs": {
        "texto": "to_str.result"
      }
    }
  ]
}
