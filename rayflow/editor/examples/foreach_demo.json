{
  "name": "foreach_demo",
  "version": "1",
  "outputs": {
    "count": "int"
  },
  "variables": [
    { "name": "counter", "type": "int", "default": 0 }
  ],
  "events": [],
  "nodes": [
    { "id": "entry", "type": "EntryItems" },
    {
      "id": "loop",
      "type": "ForEach",
      "exec_in": "entry",
      "inputs": { "array": "entry.items" }
    },
    {
      "id": "get_counter",
      "type": "Get",
      "inputs": { "variable_name": "counter" }
    },
    {
      "id": "increment",
      "type": "Add",
      "exec_in": "loop.loop_body",
      "inputs": { "a": "get_counter.value", "b": 1 }
    },
    {
      "id": "set_counter",
      "type": "Set",
      "exec_in": "increment",
      "inputs": { "variable_name": "counter", "value": "increment.result" }
    },
    {
      "id": "get_final",
      "type": "Get",
      "inputs": { "variable_name": "counter" }
    },
    {
      "id": "exit",
      "type": "FlowOutput",
      "exec_in": "loop.completed",
      "inputs": { "count": "get_final.value" }
    }
  ]
}
